# Copy to .env.local for local dev; set the same vars in the Vercel project for deploys.

# Stripe Checkout for the paid BlitzRecorder beta.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BLITZRECORDER_STRIPE_PRODUCT_ID=
BLITZRECORDER_STRIPE_PRICE_ID=
STRIPE_AUTOMATIC_TAX=false
# Optional, but recommended when multiple Stripe accounts/environments can
# create sessions. Stored with license rows for revenue/support attribution.
STRIPE_ACCOUNT_ID=

# Used to sign license keys. Generate a long random value for production:
# openssl rand -base64 48
BLITZRECORDER_LICENSE_SECRET=

# Public site URL used in Stripe success/cancel redirects.
NEXT_PUBLIC_SITE_URL=https://blitzrecorder.com

# Optional license database (Postgres; Neon pooled connection string preferred).
# When set, the Stripe webhook records every license with checkout attribution,
# Stripe account/livemode context, refunds/disputes revoke instantly, and manual
# revocation becomes possible (UPDATE blitzrecorder_licenses SET status='revoked' ...).
# When unset, the stateless Stripe-only flow keeps working unchanged.
POSTGRES_URL=

# Direct-download release signing and Sparkle update secrets are GitHub Actions
# secrets, not Vercel env vars:
# - DEVELOPER_ID_CERTIFICATE_BASE64
# - DEVELOPER_ID_CERTIFICATE_PASSWORD
# - KEYCHAIN_PASSWORD
# - ASC_KEY_ID
# - ASC_ISSUER_ID
# - ASC_PRIVATE_KEY
# - SPARKLE_PUBLIC_ED_KEY
# - SPARKLE_PRIVATE_ED_KEY
